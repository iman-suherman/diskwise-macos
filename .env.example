# Google Cloud ADC — run: npm run login (writes .gcloud/application_default_credentials.json)
GOOGLE_APPLICATION_CREDENTIALS=.gcloud/application_default_credentials.json
# Set by npm run login (or override here)
GCP_USER_EMAIL=iman.suherman@gmail.com
GCP_PROJECT_ID=personal-suherman
GCP_LOCATION=australia-southeast1

# App release upload (npm run release)
GCS_APP_BUCKET=personal-suherman-diskwise
GCS_LOCATION=australia-southeast1
GCS_APP_PREFIX=releases

# Firestore app version registry (future)
FIRESTORE_APP_COLLECTION=app_versions
FIRESTORE_APP_CATALOG=app_catalog

# Cloud Run registry API (future — npm run deploy:registry)
REGISTRY_API_SERVICE=diskwise-registry-api

# Website (npm run deploy:website)
WEBSITE_SERVICE=diskwise-website
NEXT_PUBLIC_REGISTRY_API_URL=https://diskwise-registry.suherman.net
NEXT_PUBLIC_APP_ID=diskwise-macos
NEXT_PUBLIC_DOWNLOAD_BASE_URL=https://diskwise-download.suherman.net/downloads
PUBLIC_DOWNLOAD_BASE_URL=https://diskwise-download.suherman.net/downloads
WEBSITE_BASE_URL=https://diskwise.suherman.net
SPARKLE_APPCAST_URL=https://diskwise.suherman.net/appcast.xml
DEFAULT_APP_ID=diskwise-macos

# Local Sparkle testing (Debug builds + npm run dev:website)
LOCAL_WEBSITE_URL=http://127.0.0.1:3000
LOCAL_DOWNLOAD_BASE_URL=http://127.0.0.1:3000/downloads
LOCAL_APPCAST_URL=http://127.0.0.1:3000/appcast.xml
SPARKLE_LOCAL=1

# Sparkle update signing (CI: store SPARKLE_PRIVATE_KEY as a GitHub secret)
# Generate keys locally: bash scripts/sparkle-setup-keys.sh
# Export private key for CI: .sparkle-tools/bin/generate_exported_private_key

# Deploy pipeline tuning
DISKWise_DEPLOY_BRANCH=main
DISKWise_POST_COMMIT_WEBSITE=1
DISKWise_POST_PUSH_WEBSITE=1
